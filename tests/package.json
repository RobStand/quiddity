{
  "name": "quiddity-tests",
  "version": "0.0.0",
  "private": true,
  "description": "Playwright end-to-end tests for Quiddity. Lives in a sibling folder so the app itself stays zero-dependency.",
  "scripts": {
    "install-browsers": "playwright install chromium",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0"
  }
}
